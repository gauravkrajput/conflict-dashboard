# NewsData.io - https://newsdata.io/register (Free: 200 req/day)
NEWSDATA_API_KEY=your_newsdata_api_key_here

# ACLED - https://acleddata.com/register (Free research access, 1-2 day approval)
ACLED_API_KEY=your_acled_api_key_here
ACLED_EMAIL=your_email@example.com

# OilPriceAPI.com - https://www.oilpriceapi.com/ (Free forever, no credit card)
# Replaces Alpha Vantage — purpose-built for oil & energy prices
OILPRICE_API_KEY=your_oilprice_api_key_here

# GDELT Project — No API key needed, fully open
# Queried directly at https://api.gdeltproject.org/api/v2/

# Cache revalidation interval in seconds (1800 = 30 minutes)
REVALIDATE_INTERVAL=1800
